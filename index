    "cor":[["vermelho","red"],["azul","blue"],["verde","green"],["amarelo","yellow"],
      ["preto","black"],["branco","white"],["roxo","purple"],["laranja","orange"],
      ["rosa","pink"],["marrom","brown"]],
    "animal":[["cachorro","dog"],["gato","cat"],["pássaro","bird"],["cavalo","horse"],
      ["peixe","fish"],["urso","bear"],["cobra","snake"],["lobo","wolf"],
