  },
  renderTitle(){
    $("meta-stats").innerHTML=`
      <h3>📜 REGISTROS DO AVENTUREIRO</h3>
      <div class="row"><span>Maior andar</span><b>${Meta.d.bestFloor}</b></div>
      <div class="row"><span>Maior combo</span><b>x${Meta.d.bestCombo}</b></div>
      <div class="row"><span>Palavras aprendidas</span><b>${Meta.learnedCount()}</b></div>
