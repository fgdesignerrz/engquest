/* ================= SCORER (acerto parcial) ================= */
const CONTR = {"i'm":"i am","you're":"you are","he's":"he is","she's":"she is","it's":"it is",
"we're":"we are","they're":"they are","don't":"do not","doesn't":"does not","didn't":"did not",
"can't":"can not","cannot":"can not","won't":"will not","isn't":"is not","aren't":"are not",
"wasn't":"was not","weren't":"were not","i've":"i have","you've":"you have","we've":"we have",
"they've":"they have","i'll":"i will","you'll":"you will","he'll":"he will","she'll":"she will",
"we'll":"we will","they'll":"they will","i'd":"i would","that's":"that is","what's":"what is",
"let's":"let us","o'clock":"o clock"};
const Scorer = {
  norm(s){
    s=(s||"").toLowerCase().replace(/’/g,"'").trim();
    s=s.split(/\s+/).map(w=>CONTR[w]||w).join(" ");
    return s.replace(/[^a-z0-9' ]+/g," ").replace(/'/g,"").replace(/\s+/g," ").trim();
  },
  lev(a,b){
    const m=a.length,n=b.length,d=[];
    for(let i=0;i<=m;i++)d[i]=[i];
    for(let j=0;j<=n;j++)d[0][j]=j;
    for(let i=1;i<=m;i++)for(let j=1;j<=n;j++)
      d[i][j]=Math.min(d[i-1][j]+1,d[i][j-1]+1,d[i-1][j-1]+(a[i-1]===b[j-1]?0:1));
    return d[m][n];
  },
  /* Retorna {score 0..1, ans, matched[], missing[], extra[]} */
  evaluate(given,q){
    const g=this.norm(given);
    let best={score:0,ans:q.a[0],matched:[],missing:this.norm(q.a[0]).split(" "),extra:[]};
    for(const raw of q.a){
      const A=this.norm(raw);
      if(g===A) return {score:1,ans:raw,matched:A.split(" "),missing:[],extra:[]};
      const gt=g? g.split(" "):[], at=A.split(" ");
      // tolerância a typo em resposta de 1 palavra
      if(at.length===1&&gt.length===1&&this.lev(gt[0],at[0])<=1&&at[0].length>3){
        if(0.7>best.score) best={score:0.7,ans:raw,matched:[],missing:at,extra:gt};
        continue;
      }
      const pool=[...gt]; const matched=[],missing=[];
      for(const w of at){
        let i=pool.indexOf(w);
        if(i<0){ // typo leve em palavras longas conta meio ponto via matched? conta como match fraco
          i=pool.findIndex(p=>p.length>3&&w.length>3&&this.lev(p,w)<=1);
        }
        if(i>=0){ matched.push(w); pool.splice(i,1); } else missing.push(w);
      }
      const extra=pool;
      const s=at.length? matched.length/Math.max(at.length,gt.length||1):0;
      if(s>best.score) best={score:s,ans:raw,matched,missing,extra};
    }
    return best;
  },
};

/* ================= SRS (repetição espaçada) ================= */
const Srs = {
  due(){ // primeira pergunta errada que já "venceu"
    for(const id in Meta.d.srs) if(Meta.d.srs[id].due<=Meta.d.answered) return id;
    return null;
  },
  wrong(id){
    const e=Meta.d.srs[id]||{g:0};
    e.g=0; e.due=Meta.d.answered+CFG.srs.gaps[0];
    Meta.d.srs[id]=e;
  },
  right(id){
    const e=Meta.d.srs[id]; if(!e) return;
    e.g++;
    if(e.g>=CFG.srs.gaps.length) delete Meta.d.srs[id];
    else e.due=Meta.d.answered+CFG.srs.gaps[e.g];
  },
};

/* ================= QUIZ ================= */
const Quiz = {
  recent:[],
  tierForFloor(f){ return Math.min(MAX_TIER, Math.ceil(f/2)); },
  pick(tier,noSrs){
    if(!noSrs){
      const dueId=Srs.due();
      if(dueId){ const q=QDB.find(x=>x.id===dueId); if(q) return {q,review:true}; }
    }
    let pool=QDB.filter(q=>q.tier===tier&&!this.recent.includes(q.id));
    if(!pool.length) pool=QDB.filter(q=>q.tier===tier);
    const q=pool[Math.floor(Math.random()*pool.length)];
    this.recent.push(q.id); if(this.recent.length>8) this.recent.shift();
    return {q,review:false};
  },
  registerResult(q,full,partial){
    Meta.d.answered++;
    if(full){
      Meta.d.correct++;
      Meta.d.learned[q.id]=(Meta.d.learned[q.id]||0)+1;
      Srs.right(q.id);
    } else if(!partial){
      Srs.wrong(q.id);
    } else {
      Meta.d.correct+=0; // parcial não conta como acerto pleno nas stats
      Srs.wrong(q.id);   // volta para revisão até dominar
    }
  },
};

/* ================= GACHA ================= */
const Gacha = {
  packIdxForTier(tier,partial){
    let i=PACK_BY_TIER[tier]||0;
    if(partial) i=Math.max(0,i-1);        // acerto parcial = pacote inferior
    // bônus de combo
    for(const c of CFG.combo) if(Run.combo>=c.at&&c.minPack!=null) i=Math.max(i,c.minPack);
    return i;
  },
  rollRarity(packIdx){
    const odds=[...PACKS[packIdx].odds];
    let bonus=0;
    for(const c of CFG.combo) if(Run.combo>=c.at&&c.rareBonus) bonus=c.rareBonus;
    if(bonus&&odds[0]>0){ const mv=Math.min(bonus,odds[0]); odds[0]-=mv; odds[1]+=mv; }
    let r=Math.random()*100;
    for(let i=0;i<odds.length;i++){ if(r<odds[i]) return i; r-=odds[i]; }
    return odds.length-1;
  },
  makeItem(rarIdx){
    const t=ITEM_TYPES[Math.floor(Math.random()*ITEM_TYPES.length)];
    const R=RARITIES[rarIdx];
    const fscale=1+Run.floor*0.06;
    const jitter=()=>0.85+Math.random()*0.3;
    const hp=Math.round(t.hp*R.mult*fscale*jitter());
    const dmg=Math.round(t.dmg*R.mult*fscale*jitter());
    const mats=MATERIAL[R.key];
    return { name:`${t.nome} ${mats[Math.floor(Math.random()*mats.length)]}`,
      type:t, slot:t.slot, rar:rarIdx, hp, dmg, sell:R.sell };
  },
};

/* ================= RUN (estado da partida) ================= */
const Run = {
  active:false, floor:1, gold:0, xp:0, level:1, combo:0, maxCombo:0,
  hp:0, crit:0, reviveUsed:false, equip:{}, packsOpened:0,
  enemy:null, pendingPack:null, currentQ:null, isReview:false,
  battleTimer:null, inCombat:false, answering:false, goldEarned:0,
  reset(){
    this.active=true; this.floor=1; this.gold=0; this.xp=0; this.level=1;
    this.combo=0; this.maxCombo=0; this.crit=0; this.reviveUsed=false;
    this.equip={}; this.packsOpened=0; this.goldEarned=0;
    this.pendingPack=null; this.currentQ=null; Quiz.recent=[];
    if(this.battleTimer){ clearInterval(this.battleTimer); this.battleTimer=null; }
    this.inCombat=false; this.answering=false;
    this.hp=this.maxHp();
  },
  bonus(){ let hp=0,dmg=0; for(const s of SLOTS){ const it=this.equip[s]; if(it){hp+=it.hp; dmg+=it.dmg;} } return {hp,dmg}; },
  maxHp(){ return CFG.player.baseHp+(this.level-1)*CFG.level.hpPerLevel+this.bonus().hp; },
  dmg(){ return CFG.player.baseDmg+(this.level-1)*CFG.level.dmgPerLevel+this.bonus().dmg; },
  addXp(n){
    this.xp+=n;
    while(this.xp>=this.level*CFG.level.xpPerLevel){
      this.xp-=this.level*CFG.level.xpPerLevel; this.level++;
      this.hp=Math.min(this.maxHp(),this.hp+10);
      Sfx.levelup(); UI.toast(`⬆️ LEVEL ${this.level}! +${CFG.level.hpPerLevel} HP, +${CFG.level.dmgPerLevel} DMG`);
    }
  },
  addGold(n){ this.gold+=n; if(n>0) this.goldEarned+=n; },
};

/* ================= COMBAT ================= */
const Combat = {
  enemyFor(f){
    const boss=f%CFG.enemy.bossEvery===0;
    const base=boss? BOSS: ENEMIES[(Math.ceil(f/1)-1)%ENEMIES.length];
    const mult=boss? CFG.enemy.bossMult:1;
    return { name:boss? `👑 ${base.name}`:base.name, spr:base.spr, pal:base.pal, boss,
      maxHp:Math.round(CFG.enemy.hp(f)*mult), hp:Math.round(CFG.enemy.hp(f)*mult),
      dmg:Math.round(CFG.enemy.dmg(f)*(boss?1.25:1)) };
  },
  stop(){ if(Run.battleTimer){ clearInterval(Run.battleTimer); Run.battleTimer=null; } Run.inCombat=false; },
  start(){
    // Guarda anti-duplicação: nunca deixa dois timers de combate rodando ao mesmo
    // tempo (double-tap em botões criava um "timer fantasma" que pulava fases).
    this.stop();
    Run.inCombat=true;
    UI.setBattleUi(true);
    let heroTurn=true;
    Run.battleTimer=setInterval(()=>{
      if(!Run.active||!Run.inCombat){ this.stop(); return; }
      if(heroTurn){
        const crit=Math.random()<Run.crit;
        const d=Math.round(Run.dmg()*(crit?2:1));
        Run.enemy.hp=Math.max(0,Run.enemy.hp-d);
        UI.hitFx("enemy",d,crit); Sfx.hit();
        if(Run.enemy.hp<=0){ this.stop(); setTimeout(()=>Game.floorClear(),500); return; }
      } else {
        Run.hp=Math.max(0,Run.hp-Run.enemy.dmg);
        UI.hitFx("hero",Run.enemy.dmg,false); Sfx.hit();
        if(Run.hp<=0){ this.stop(); setTimeout(()=>Game.playerDown(),500); return; }
      }
      heroTurn=!heroTurn; UI.refreshBars();
    },420);
  },
};

/* ================= UI ================= */
const $=(id)=>document.getElementById(id);
const UI = {
  drawSprite(cv,rows,pal,scale){
    const w=rows[0].length,h=rows.length;
    cv.width=w*scale; cv.height=h*scale;
    const c=cv.getContext("2d");
    c.clearRect(0,0,cv.width,cv.height);
    for(let y=0;y<h;y++)for(let x=0;x<w;x++){
      const ch=rows[y][x]; if(ch==="."||!pal[ch]) continue;
      c.fillStyle=pal[ch]; c.fillRect(x*scale,y*scale,scale,scale);
    }
  },
  itemPal(rarIdx){
    const col=getComputedStyle(document.documentElement).getPropertyValue("--r-"+RARITIES[rarIdx].key).trim();
    return { o:"#0a0816","1":col,"2":"#8a5a2b","3":"#fff0b0" };
  },
  show(id){ document.querySelectorAll(".screen").forEach(s=>s.classList.remove("on")); $(id).classList.add("on"); },
  modal(html){ $("modal").innerHTML=html; $("ovl").classList.add("on"); },
  closeModal(){ $("ovl").classList.remove("on"); },
  // Vincula um clique de disparo ÚNICO: mesmo com double-tap (comum no celular),
  // o handler roda só uma vez e o botão fica travado, evitando ações duplicadas.
  once(el,fn){
    if(!el) return;
    el.onclick=(e)=>{ if(el.dataset.fired) return; el.dataset.fired="1"; el.style.pointerEvents="none"; fn(e); };
  },
  toast(msg,ms){
    const t=$("toast"); t.textContent=msg; t.classList.remove("on");
    void t.offsetWidth; t.classList.add("on");
    clearTimeout(this._tt); this._tt=setTimeout(()=>t.classList.remove("on"),ms||1800);
  },
  refreshHud(){
    $("chip-floor").innerHTML=`🏰 <b>Andar ${Run.floor}</b>`;
    $("chip-gold").innerHTML=`🪙 <b>${Run.gold}</b>`;
    $("chip-xp").innerHTML=`⭐ <b>LV ${Run.level}</b> <span style="color:var(--ink-dim)">${Run.xp}/${Run.level*CFG.level.xpPerLevel}</span>`;
    const chipC=$("chip-combo");
    chipC.innerHTML=`🔥 <b>x${Run.combo}</b>`;
    chipC.classList.toggle("hot",Run.combo>=5);
    for(const k of ["heal","pack","crit"]) $("shop-"+k).disabled=Run.gold<CFG.shop[k].cost;
  },
  refreshBars(){
    const hMax=Run.maxHp();
    $("hero-hp-i").style.width=Math.max(0,100*Run.hp/hMax)+"%";
    $("hero-hp-t").textContent=`${Run.hp}/${hMax}`;
    if(Run.enemy){
      $("enemy-hp-i").style.width=Math.max(0,100*Run.enemy.hp/Run.enemy.maxHp)+"%";
      $("enemy-hp-t").textContent=`${Run.enemy.hp}/${Run.enemy.maxHp}`;
    }
  },
  renderArena(){
    this.drawSprite($("hero-cv"),SPR.hero,HERO_PAL,Run.enemy&&Run.enemy.boss?6:7);
    this.drawSprite($("enemy-cv"),SPR[Run.enemy.spr],Run.enemy.pal,Run.enemy.boss?9:7);
    $("enemy-name").textContent=Run.enemy.name;
    $("hero-name").textContent=`Herói · ⚔️${Run.dmg()}${Run.crit?` · 💥${Math.round(Run.crit*100)}%`:""}`;
    $("boss-tag").style.display=Run.enemy.boss?"block":"none";
    this.refreshBars();
  },
  hitFx(side,dmg,crit){
    const f=document.querySelector(".fighter."+side);
    const cv=f.querySelector("canvas");
    cv.classList.remove("hitflash"); void cv.offsetWidth; cv.classList.add("hitflash");
    const el=document.createElement("div");
    el.className="dmgfloat"; el.textContent=(crit?"💥":"-")+dmg;
    el.style.color=crit?"var(--gold)":(side==="hero"?"var(--hp)":"#fff");
    el.style.left=(f.offsetLeft+40+Math.random()*30)+"px";
    el.style.top=(f.offsetTop+10)+"px";
    $("arena").appendChild(el); setTimeout(()=>el.remove(),850);
  },
  setBattleUi(on){
    $("qarea").innerHTML=on? `<div class="qcard pxbox" style="text-align:center; color:var(--ink-dim); font-size:9px;">⚔️ Combate automático em andamento...</div>`:"";
    $("shop").style.display=on?"none":"flex";
  },
  particles(n,colors){
    const app=$("app");
    for(let i=0;i<n;i++){
      const p=document.createElement("div"); p.className="part";
      p.style.background=colors[i%colors.length];
      p.style.left="50%"; p.style.top="45%";
      p.style.setProperty("--dx",(Math.random()*360-180)+"px");
      p.style.setProperty("--dy",(Math.random()*360-220)+"px");
      app.appendChild(p); setTimeout(()=>p.remove(),950);
    }
  },
  flash(){ const f=$("flash"); f.classList.remove("go"); void f.offsetWidth; f.classList.add("go"); },
  quake(){ const a=$("app"); a.classList.remove("quake"); void a.offsetWidth; a.classList.add("quake"); },
};

/* ================= GAME FLOW ================= */
const Game = {
  async init(){
    await Meta.load();
