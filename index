    Run.addGold(-s.cost); Sfx.coin();
    if(k==="heal"){ Run.hp=Math.min(Run.maxHp(),Run.hp+Math.round(Run.maxHp()*0.5)); UI.toast("❤️ +50% HP!"); }
    if(k==="crit"){ Run.crit=Math.min(0.5,Run.crit+0.1); UI.toast(`💥 Crítico: ${Math.round(Run.crit*100)}%`); UI.renderArena(); }
    if(k==="pack"){ const idx=Gacha.packIdxForTier(Quiz.tierForFloor(Run.floor),false); this.openPack(idx,null); }
    UI.refreshHud(); UI.refreshBars();
  },
  /* ---------- INVENTÁRIO ---------- */
  showInventory(){
    const b=Run.bonus();
    let grid="";
    for(const s of SLOTS){
      const it=Run.equip[s];
      grid+=it?`
        <div class="slot pxbox"><canvas id="inv-${s}"></canvas>
          <div class="sn r-${RARITIES[it.rar].key}">${it.type.nome}</div>
          <div class="sn">❤️${it.hp} ⚔️${it.dmg}</div></div>`:
        `<div class="slot pxbox empty"><div style="font-size:16px;margin:12px 0 6px">·</div><div class="sn">${s}</div></div>`;
    }
    UI.modal(`
      <h2>🎒 INVENTÁRIO</h2>
      <div id="invgrid">${grid}</div>
      <div class="invtotal"><span>❤️ Bônus: <b style="color:var(--hp2)">+${b.hp}</b></span>
        <span>⚔️ Bônus: <b style="color:var(--torch)">+${b.dmg}</b></span></div>
      <div class="qactions" style="justify-content:center; margin-top:12px;">
        <button class="btn ghost" onclick="UI.closeModal()">FECHAR</button></div>`);
    for(const s of SLOTS){ const it=Run.equip[s];
      if(it) UI.drawSprite($("inv-"+s),SPR[it.type.sprite],UI.itemPal(it.rar),4); }
  },
  /* ---------- FLUXO DE ANDAR / MORTE ---------- */
  floorClear(){
    UI.toast(Run.enemy.boss?"👑 BOSS DERROTADO!!":"✔ Inimigo derrotado!");
    if(Run.enemy.boss){ Sfx.levelup(); UI.particles(16,["#ffd23c","#fff"]); Run.addGold(30); }
    Run.floor++;
    Meta.d.bestFloor=Math.max(Meta.d.bestFloor,Run.floor-1);
    Meta.d.bestCombo=Math.max(Meta.d.bestCombo,Run.maxCombo);
    Meta.save();
    setTimeout(()=>this.startFloor(),700);
  },
  playerDown(){
    if(Run.reviveUsed){ this.gameOver(); return; }
    Run.reviveUsed=true;
    const tier=Math.min(MAX_TIER,Quiz.tierForFloor(Run.floor)+2);
    const {q}=Quiz.pick(tier,true);
    let ptext=q.p, dialog="";
    if(q.p.includes("|||")){ const pr=q.p.split("|||"); dialog=`<span class="dialog">💬 ${pr[0]}</span>`; ptext=pr[1]; }
    UI.modal(`
      <div class="skullbig">💀</div>
      <h2 style="color:var(--hp)">VOCÊ CAIU!</h2>
      <div style="font-size:8px; color:var(--ink-dim); margin-bottom:10px;">
        Última chance: acerte esta pergunta <b style="color:var(--r-epico)">TIER ${q.tier}</b> para reviver!</div>
      <div class="qcard pxbox" style="text-align:left;">
        <div class="qtext">${dialog}${ptext}</div>
        <input id="rv-answer" type="text" autocomplete="off" autocapitalize="off" placeholder="Resposta perfeita ou fim...">
        <div class="qactions"><button class="btn" id="rv-send">REVIVER ✨</button></div>
      </div>`);
    UI.once($("rv-send"),()=>{
      const r=Scorer.evaluate($("rv-answer").value,q);
      Quiz.registerResult(q,r.score>=CFG.score.full,false);
      if(r.score>=CFG.score.full){
        Run.hp=Math.round(Run.maxHp()*CFG.player.reviveHp);
        UI.closeModal(); UI.flash(); Sfx.levelup();
        UI.toast("✨ REVIVEU COM "+Math.round(CFG.player.reviveHp*100)+"% DE HP!");
        UI.refreshBars(); Combat.start();
      } else {
        UI.closeModal();
        UI.toast(`A resposta era: "${r.ans}"`,2600);
        setTimeout(()=>this.gameOver(),1200);
      }
    });
    $("rv-answer").addEventListener("keydown",e=>{ if(e.key==="Enter") $("rv-send").click(); });
  },
  gameOver(){
    Run.active=false;
    Meta.d.bestFloor=Math.max(Meta.d.bestFloor,Run.floor);
    Meta.d.bestCombo=Math.max(Meta.d.bestCombo,Run.maxCombo);
    Meta.save();
    $("sum-content").innerHTML=`
      <div class="skullbig">⚰️</div>
      <h2 style="color:var(--hp); font-size:14px; margin-bottom:14px;">FIM DA RUN</h2>
      <div class="pxbox" style="padding:14px; text-align:left;">
        <div class="sumrow"><span>🏰 Andar alcançado</span><b>${Run.floor}</b></div>
        <div class="sumrow"><span>🔥 Maior combo</span><b>x${Run.maxCombo}</b></div>
        <div class="sumrow"><span>📦 Pacotes abertos</span><b>${Run.packsOpened}</b></div>
        <div class="sumrow"><span>🪙 Ouro ganho</span><b>${Run.goldEarned}</b></div>
        <div class="sumrow"><span>⭐ Nível final</span><b>${Run.level}</b></div>
      </div>
      <div class="pxbox" style="padding:14px; text-align:left; margin-top:10px;">
        <div style="font-size:8px; color:var(--torch); margin-bottom:6px;">📜 RECORDES PERMANENTES</div>
        <div class="sumrow"><span>Maior andar</span><b>${Meta.d.bestFloor}</b></div>
        <div class="sumrow"><span>Palavras aprendidas</span><b>${Meta.learnedCount()}</b></div>
        <div class="sumrow"><span>Precisão geral</span><b>${Meta.acc()}%</b></div>
      </div>
      <div style="font-size:8px; color:var(--ink-dim); margin-top:12px;">
        Equipamentos perdidos... mas o inglês fica com você. 🧠</div>`;
    UI.show("scr-summary");
  },
};

window.addEventListener("DOMContentLoaded",()=>Game.init());

</script>
</body>
</html>
