    ["ligar (aparelho)",["turn on"],"TURN ON = ligar","Turn on the TV."],
    ["encontrar por acaso",["run into","bump into"],"RUN INTO = topar com alguém","I ran into an old friend."],
  ];
  for(const [pt,ans,note,ex] of t6)
    add(6,`Phrasal verb para "${pt}":`,ans,`${pt} = ${ans[0]}`,`Ex.: "${ex}"`,note);

  /* ---- TIER 7: expressões idiomáticas ---- */
  const t7 = [
    ["Está chovendo canivetes (chovendo MUITO)",["it is raining cats and dogs"],"Idiom clássico para chuva forte."],
    ["De vez em quando",["once in a while","from time to time"],"ONCE IN A WHILE = de vez em quando."],
