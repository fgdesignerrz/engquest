    "número":[["três","three"],["cinco","five"],["sete","seven"],["nove","nine"],
      ["dez","ten"],["doze","twelve"],["vinte","twenty"],["cem","one hundred","a hundred","hundred"]],
  };
  for(const cat in t1) for(const e of t1[cat]){
    const [pt,...ans]=e;
    add(1, `Como se diz "${pt}" em inglês? (${cat})`, ans,
      `${pt} = ${ans[0]}`, `Ex.: "I see the ${ans[0]}."`,
      `Vocabulário básico — categoria: ${cat}.`);
  }

  /* ---- TIER 2: frases curtas ---- */
  const t2 = [
    ["Eu gosto de café",["i like coffee"],"Presente simples: sujeito + verbo."],
    ["Ela é minha amiga",["she is my friend"],"Verbo TO BE: she is."],
    ["O gato está dormindo",["the cat is sleeping"],"Presente contínuo: is + verbo-ING."],
    ["Nós estamos felizes",["we are happy"],"TO BE no plural: we are."],
    ["Eu tenho um cachorro",["i have a dog"],"HAVE = ter. Artigo A antes de consoante."],
    ["Ele corre rápido",["he runs fast"],"3ª pessoa: verbo ganha -S (runs)."],
    ["A porta está aberta",["the door is open"],"OPEN aqui é adjetivo (aberta)."],
    ["Eu quero água",["i want water"],"WANT = querer. Water não usa artigo aqui."],
    ["Eles estão em casa",["they are at home","they are home"],"AT HOME = em casa."],
    ["O livro é novo",["the book is new"],"Adjetivo vem depois do TO BE."],
