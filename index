        <div class="istats"><span>❤️ <b>+${item.hp}</b></span><span>⚔️ <b>+${item.dmg}</b></span></div>
        <div class="cmp">vs equipado (${item.slot}): ❤️${arrow(dHp)} ⚔️${arrow(dDmg)}</div>
