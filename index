/* ================= SFX (WebAudio, sem assets) ================= */
const Sfx = {
  ctx:null,
  ensure(){ if(!this.ctx){ try{ this.ctx = new (window.AudioContext||window.webkitAudioContext)(); }catch(e){} } if(this.ctx&&this.ctx.state==="suspended") this.ctx.resume(); },
  tone(f,dur,type,delay,vol){
    if(!this.ctx) return;
    const t=this.ctx.currentTime+(delay||0);
    const o=this.ctx.createOscillator(), g=this.ctx.createGain();
    o.type=type||"square"; o.frequency.value=f;
    g.gain.setValueAtTime(vol||0.06,t); g.gain.exponentialRampToValueAtTime(0.001,t+dur);
    o.connect(g); g.connect(this.ctx.destination); o.start(t); o.stop(t+dur);
  },
  seq(notes,step,type,vol){ this.ensure(); notes.forEach((f,i)=>this.tone(f,step*1.6,type,i*step,vol)); },
  ok(){ this.seq([523,659,784],0.09); },
  partial(){ this.seq([440,554],0.1); },
  bad(){ this.ensure(); this.tone(196,0.25,"sawtooth",0,0.05); this.tone(147,0.3,"sawtooth",0.12,0.05); },
  coin(){ this.ensure(); this.tone(1175,0.06,"square",0,0.04); this.tone(1568,0.12,"square",0.06,0.04); },
  hit(){ this.ensure(); this.tone(98,0.08,"sawtooth",0,0.07); },
  pack(){ this.seq([294,392,494,587],0.07,"triangle"); },
  drop(r){ const a=[[523,659],[523,659,784],[523,659,784,1046],[392,523,659,784,1046],[392,523,659,784,1046,1318,1568]][r]||[523];
    this.seq(a,0.11,"triangle",0.07); },
  levelup(){ this.seq([392,523,659,784],0.1,"triangle"); },
};

