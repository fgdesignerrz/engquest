  /* ---- TIER 3: frases médias ---- */
  const t3 = [
    ["Eu vou ao mercado amanhã",["i will go to the market tomorrow","i am going to the market tomorrow"],"Futuro com WILL ou GOING TO."],
    ["Meu irmão trabalha em um hospital",["my brother works in a hospital","my brother works at a hospital"],"3ª pessoa: works. IN/AT a hospital."],
    ["Nós assistimos um filme ontem à noite",["we watched a movie last night"],"Passado: watched. LAST NIGHT = ontem à noite."],
    ["Ela sempre bebe café de manhã",["she always drinks coffee in the morning"],"Advérbio ALWAYS antes do verbo."],
    ["O cachorro está correndo no parque",["the dog is running in the park"],"Contínuo: is running. Dobra o N (run→running)."],
    ["Eu preciso comprar sapatos novos",["i need to buy new shoes"],"NEED TO + verbo. Adjetivo antes do substantivo."],
    ["Eles moram perto da praia",["they live near the beach","they live close to the beach"],"NEAR = perto de."],
    ["Você pode me ajudar, por favor?",["can you help me please","could you help me please"],"CAN/COULD para pedidos."],
