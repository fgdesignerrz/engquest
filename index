function buildQuestions(){
  const Q = [];
  let seq = 0;
  const add = (tier,p,a,tr,ex,note)=>Q.push({id:"q"+(seq++),tier,p,a,tr,ex,note});

  /* ---- TIER 1: palavras isoladas ---- */
