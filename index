  ];
  for(const [pt,ans,note] of t7)
    add(7,`Expressão em inglês: "${pt}"`,ans,`${pt} = ${ans[0]}`,`Ex.: "${cap(ans[0])}."`,note);

  /* ---- TIER 8: diálogos ---- */
  const t8 = [
