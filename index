<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<title>EngQuest — Roguelike de Inglês</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Press+Start+2P&display=swap" rel="stylesheet">
<style>
/* ============================================================
   ENGQUEST — Roguelike + Gacha de Inglês
   Paleta: noite profunda #0d0b1a / painel #1a1730 / tocha #ffb545
   Raridades: comum cinza, raro azul, épico roxo, lendário dourado,
   místico rosa-arco-íris (animado)
   ============================================================ */
:root{
  --bg:#0d0b1a; --bg2:#141126; --panel:#1a1730; --panel2:#221d40;
  --line:#3a3560; --line2:#565092;
  --ink:#e8e4ff; --ink-dim:#9a94c2;
  --torch:#ffb545; --hp:#ff5a6e; --hp2:#67e06a; --xp:#5ad4ff; --gold:#ffd23c;
  --ok:#67e06a; --warn:#ffb545; --bad:#ff5a6e;
  --r-comum:#9aa0b0; --r-raro:#4da6ff; --r-epico:#b478ff;
  --r-lendario:#ffc93c; --r-mistico:#ff4dd8;
  --px:3px;
}
*{box-sizing:border-box; margin:0; padding:0; -webkit-tap-highlight-color:transparent;}
html,body{height:100%;}
body{
  background:var(--bg); color:var(--ink);
  font-family:'Press Start 2P','Courier New',monospace;
  font-size:11px; line-height:1.7;
  image-rendering:pixelated; overflow:hidden;
  user-select:none;
}
body::after{ /* scanlines sutis */
  content:""; position:fixed; inset:0; pointer-events:none; z-index:99;
  background:repeating-linear-gradient(0deg, rgba(0,0,0,.12) 0 1px, transparent 1px 3px);
  opacity:.5;
}
canvas{image-rendering:pixelated;}
button{font-family:inherit;}
input{font-family:inherit;}

/* ---- borda pixelada (degraus) ---- */
.pxbox{
  background:var(--panel); position:relative;
  box-shadow:
    0 calc(-1*var(--px)) 0 0 var(--line), 0 var(--px) 0 0 var(--line),
    calc(-1*var(--px)) 0 0 0 var(--line), var(--px) 0 0 0 var(--line);
  margin:var(--px);
}

/* ---- app frame ---- */
#app{max-width:520px; height:100dvh; margin:0 auto; display:flex; flex-direction:column; position:relative; overflow:hidden;}
.screen{display:none; flex-direction:column; height:100%; overflow:hidden;}
.screen.on{display:flex;}

/* ============ TÍTULO ============ */
#scr-title{align-items:center; justify-content:center; gap:18px; text-align:center; padding:20px;
  background:radial-gradient(ellipse at 50% 20%, #241d4d 0%, var(--bg) 65%);}
.logo{font-size:26px; letter-spacing:2px; line-height:1.4;
  color:var(--torch); text-shadow:0 4px 0 #7a3d00, 0 0 24px rgba(255,181,69,.45);
  animation:float 3s ease-in-out infinite;}
.logo em{font-style:normal; color:var(--xp); text-shadow:0 4px 0 #114a66,0 0 24px rgba(90,212,255,.4);}
.tagline{color:var(--ink-dim); font-size:9px;}
.title-stats{width:100%; max-width:360px; padding:14px; font-size:8px; text-align:left; color:var(--ink-dim);}
.title-stats h3{color:var(--torch); font-size:9px; margin-bottom:8px;}
.title-stats .row{display:flex; justify-content:space-between; margin:4px 0;}
.title-stats .row b{color:var(--ink);}

/* ============ BOTÕES ============ */
.btn{
  display:inline-block; cursor:pointer; border:0; color:#1a1200;
  background:var(--torch); padding:12px 18px; font-size:11px;
  box-shadow:0 calc(-1*var(--px)) 0 0 #ffd98d, 0 var(--px) 0 0 #a35f00,
    calc(-1*var(--px)) 0 0 0 #c98524, var(--px) 0 0 0 #c98524,
    0 calc(2*var(--px)) 0 0 #5c3400;
  transition:transform .06s;
}
.btn:active{transform:translateY(var(--px)); box-shadow:0 calc(-1*var(--px)) 0 0 #ffd98d, 0 var(--px) 0 0 #a35f00, calc(-1*var(--px)) 0 0 0 #c98524, var(--px) 0 0 0 #c98524;}
.btn.blue{background:var(--xp); color:#00202e; box-shadow:0 calc(-1*var(--px)) 0 0 #b3ecff,0 var(--px) 0 0 #1c6f8f, calc(-1*var(--px)) 0 0 0 #3596bd, var(--px) 0 0 0 #3596bd, 0 calc(2*var(--px)) 0 0 #0d3c50;}
.btn.ghost{background:var(--panel2); color:var(--ink); box-shadow:0 calc(-1*var(--px)) 0 0 var(--line2),0 var(--px) 0 0 #100d22, calc(-1*var(--px)) 0 0 0 var(--line), var(--px) 0 0 0 var(--line), 0 calc(2*var(--px)) 0 0 #0a0816;}
.btn.small{padding:8px 10px; font-size:8px;}
.btn:disabled{opacity:.4; pointer-events:none;}

/* ============ HUD ============ */
#hud{display:flex; flex-wrap:wrap; gap:6px; padding:8px 10px 4px; justify-content:center;}
.chip{font-size:8px; padding:6px 8px; background:var(--panel); display:flex; align-items:center; gap:5px;
  box-shadow:0 -2px 0 0 var(--line),0 2px 0 0 var(--line),-2px 0 0 0 var(--line),2px 0 0 0 var(--line); margin:2px;}
.chip b{font-size:9px;}
.chip.gold b{color:var(--gold);} .chip.xp b{color:var(--xp);}
.chip.floor b{color:var(--torch);} .chip.combo b{color:var(--r-epico);}
.chip.combo.hot{animation:glowPulse 1s infinite; color:var(--r-lendario);}

/* ============ ARENA ============ */
#arena{position:relative; height:172px; margin:6px 10px 2px; overflow:hidden;
  background:linear-gradient(#181433 0%, #221b45 55%, #17122e 56%, #100d22 100%);
  box-shadow:0 -3px 0 0 var(--line),0 3px 0 0 var(--line),-3px 0 0 0 var(--line),3px 0 0 0 var(--line);}
#arena .torch{position:absolute; top:12px; width:8px; height:14px; background:var(--torch);
  box-shadow:0 0 18px 6px rgba(255,181,69,.25); animation:flick .35s steps(2) infinite alternate;}
#arena .torch.l{left:16px;} #arena .torch.r{right:16px;}
.fighter{position:absolute; bottom:26px; text-align:center; width:130px;}
.fighter .name{font-size:7px; color:var(--ink-dim); margin-bottom:3px; white-space:nowrap; overflow:hidden;}
.fighter.hero{left:8px;} .fighter.enemy{right:8px;}
.fighter canvas{display:block; margin:0 auto;}
.fighter.hero canvas{animation:idleHero 1.1s steps(2) infinite;}
.fighter.enemy canvas{animation:idleFoe 1.3s steps(2) infinite;}
.hpbar{height:10px; background:#0a0816; margin-top:4px; position:relative;
  box-shadow:0 -2px 0 0 var(--line),0 2px 0 0 var(--line),-2px 0 0 0 var(--line),2px 0 0 0 var(--line);}
.hpbar i{display:block; height:100%; background:var(--hp2); transition:width .25s steps(8);}
.fighter.enemy .hpbar i{background:var(--hp);}
.hpbar span{position:absolute; inset:0; font-size:7px; text-align:center; line-height:10px; color:#fff; text-shadow:1px 1px 0 #000;}
.boss-tag{position:absolute; top:8px; left:50%; transform:translateX(-50%); color:var(--hp);
  font-size:10px; text-shadow:0 0 12px rgba(255,90,110,.8); animation:glowPulse .8s infinite;}
.dmgfloat{position:absolute; font-size:12px; font-weight:bold; pointer-events:none; animation:dmgUp .8s forwards; text-shadow:2px 2px 0 #000; z-index:5;}
.hitflash{animation:hitFlash .25s steps(2) 2 !important;}

/* ============ PAINEL DE PERGUNTA ============ */
/* #panel é um contêiner de rolagem em bloco. Como flex-column, o filho único
   era dimensionado ao espaço livre e o conteúdo alto (feedback de acerto parcial)
   ficava cortado sem rolagem, deixando o botão CONTINUAR inacessível. */
#panel{flex:1; min-height:0; overflow-y:auto; -webkit-overflow-scrolling:touch; padding:6px 10px 12px;}
#panel #qarea{margin-bottom:8px;}
.qcard{padding:12px;}
.qtier{font-size:7px; color:var(--xp); margin-bottom:8px; display:flex; justify-content:space-between; align-items:center;}
.qtier .rev{color:var(--r-epico);}
.qtext{font-size:11px; line-height:1.9; color:var(--ink); margin-bottom:10px;}
.qtext .dialog{display:block; color:var(--ink-dim); font-size:9px; margin-bottom:6px;}
#answer{width:100%; background:#0a0816; border:0; color:var(--ink); padding:12px; font-size:11px;
  box-shadow:0 -3px 0 0 var(--line),0 3px 0 0 var(--line),-3px 0 0 0 var(--line),3px 0 0 0 var(--line); margin:3px 0 10px;}
#answer:focus{outline:none; box-shadow:0 -3px 0 0 var(--xp),0 3px 0 0 var(--xp),-3px 0 0 0 var(--xp),3px 0 0 0 var(--xp);}
.qactions{display:flex; gap:10px; flex-wrap:wrap;}

/* ---- loja rápida ---- */
#shop{display:flex; gap:6px; flex-wrap:wrap; justify-content:center;}
#shop .btn{flex:1; min-width:100px;}

/* ============ FEEDBACK ============ */
.fb{padding:12px; animation:slideUp .25s;}
.fb .head{font-size:12px; margin-bottom:8px;}
.fb.ok .head{color:var(--ok);} .fb.partial .head{color:var(--warn);} .fb.bad .head{color:var(--bad);}
.fb .pct{font-size:20px; margin:4px 0 10px;}
.fb .line{font-size:9px; color:var(--ink-dim); margin:7px 0; line-height:1.8;}
.fb .line b{color:var(--ink);}
.fb .wordok{color:var(--ok);} .fb .wordbad{color:var(--bad); text-decoration:line-through;}
.fb .wordmiss{color:var(--warn);}
.fb .rewards{display:flex; gap:10px; margin:10px 0; font-size:9px; flex-wrap:wrap;}
.fb .rewards span{animation:pop .3s;}

/* ============ MODAIS ============ */
.overlay{position:absolute; inset:0; background:rgba(6,4,14,.86); z-index:20;
  display:none; align-items:center; justify-content:center; padding:16px;}
.overlay.on{display:flex;}
.modal{width:100%; max-width:360px; padding:18px; text-align:center; animation:slideUp .22s; max-height:92%; overflow-y:auto;}
.modal h2{font-size:12px; margin-bottom:12px; color:var(--torch);}

/* ---- pacote ---- */
.packwrap{padding:26px 0 12px;}
.pack{width:92px; height:92px; margin:0 auto 14px; position:relative; cursor:pointer;
  display:flex; align-items:center; justify-content:center; font-size:30px;
  animation:packShake .5s ease-in-out infinite;}
.pack::before{content:""; position:absolute; inset:0; background:var(--pc,#666);
  box-shadow:0 -4px 0 0 var(--pcl,#999),0 4px 0 0 var(--pcd,#333),-4px 0 0 0 var(--pcd,#333),4px 0 0 0 var(--pcl,#999);}
.pack::after{content:""; position:absolute; left:0; right:0; top:38px; height:14px; background:var(--pcd,#333);}
.pack span{position:relative; z-index:2; text-shadow:2px 2px 0 #000;}
.pack.opening{animation:packBurst .45s forwards;}
.packname{font-size:10px; margin-bottom:6px;}
.packhint{font-size:8px; color:var(--ink-dim);}

/* ---- carta de item ---- */
.itemcard{padding:16px; margin:6px auto; max-width:280px; position:relative; animation:pop .35s;}
.itemcard .rar{font-size:8px; letter-spacing:1px; margin-bottom:8px;}
.itemcard canvas{margin:6px auto; display:block; filter:drop-shadow(0 0 10px var(--rc,transparent));}
.itemcard .iname{font-size:11px; margin:8px 0; line-height:1.6;}
.itemcard .istats{font-size:9px; color:var(--ink-dim); display:flex; gap:14px; justify-content:center; margin-bottom:6px;}
.itemcard .istats b{color:var(--ink);}
.itemcard .cmp{font-size:8px; margin:6px 0;}
.cmp .up{color:var(--ok);} .cmp .down{color:var(--bad);} .cmp .eq{color:var(--ink-dim);}
.r-comum{color:var(--r-comum); --rc:var(--r-comum);}
.r-raro{color:var(--r-raro); --rc:var(--r-raro);}
.r-epico{color:var(--r-epico); --rc:var(--r-epico);}
.r-lendario{color:var(--r-lendario); --rc:var(--r-lendario);}
.r-mistico{--rc:var(--r-mistico); animation:rainbowTx 1.4s linear infinite;}
.itemcard.mistico{animation:pop .35s, mysticGlow 1.6s linear infinite;}
.flash{position:fixed; inset:0; z-index:60; pointer-events:none; opacity:0;}
.flash.go{animation:whiteFlash .5s;}
#app.quake{animation:quake .45s;}

/* partículas */
.part{position:absolute; width:6px; height:6px; z-index:65; pointer-events:none; animation:partFly .9s forwards;}

/* ---- inventário ---- */
#invgrid{display:grid; grid-template-columns:repeat(4,1fr); gap:8px; margin:10px 0;}
.slot{padding:6px 2px; font-size:6px; color:var(--ink-dim); text-align:center; min-height:64px;}
.slot canvas{display:block; margin:2px auto;}
.slot .sn{font-size:6px; line-height:1.4;}
.slot.empty{opacity:.35;}
.invtotal{font-size:9px; display:flex; justify-content:center; gap:16px; margin-top:8px;}

/* ---- reviver / fim ---- */
.skullbig{font-size:40px; margin:8px 0; animation:float 2s infinite;}
.sumrow{display:flex; justify-content:space-between; font-size:9px; margin:6px 0; color:var(--ink-dim);}
.sumrow b{color:var(--ink);}

/* toast */
#toast{position:absolute; top:12px; left:50%; transform:translateX(-50%); z-index:70; font-size:9px;
  background:var(--panel2); padding:10px 14px; display:none;
  box-shadow:0 -3px 0 0 var(--line2),0 3px 0 0 var(--line2),-3px 0 0 0 var(--line2),3px 0 0 0 var(--line2);}
#toast.on{display:block; animation:slideUp .2s;}

/* ============ ANIMAÇÕES ============ */
@keyframes float{0%,100%{transform:translateY(0)}50%{transform:translateY(-6px)}}
@keyframes flick{from{opacity:.7; height:12px}to{opacity:1; height:16px}}
@keyframes idleHero{0%,100%{transform:translateY(0)}50%{transform:translateY(-3px)}}
@keyframes idleFoe{0%,100%{transform:translateY(0) scaleX(-1)}50%{transform:translateY(-4px) scaleX(-1)}}
@keyframes glowPulse{0%,100%{filter:brightness(1)}50%{filter:brightness(1.6)}}
@keyframes dmgUp{0%{opacity:1; transform:translateY(0)}100%{opacity:0; transform:translateY(-34px)}}
@keyframes hitFlash{0%{filter:brightness(3) saturate(0)}100%{filter:none}}
@keyframes slideUp{from{opacity:0; transform:translateY(14px)}to{opacity:1; transform:none}}
@keyframes pop{0%{transform:scale(.4); opacity:0}70%{transform:scale(1.12)}100%{transform:scale(1); opacity:1}}
@keyframes packShake{0%,100%{transform:rotate(0)}20%{transform:rotate(-4deg)}60%{transform:rotate(4deg)}}
@keyframes packBurst{0%{transform:scale(1)}60%{transform:scale(1.25)}100%{transform:scale(0); opacity:0}}
@keyframes rainbowTx{0%{color:#ff4dd8}25%{color:#ffc93c}50%{color:#5ad4ff}75%{color:#b478ff}100%{color:#ff4dd8}}
@keyframes mysticGlow{0%{box-shadow:0 0 24px 4px rgba(255,77,216,.6)}33%{box-shadow:0 0 24px 4px rgba(90,212,255,.6)}66%{box-shadow:0 0 24px 4px rgba(255,201,60,.6)}100%{box-shadow:0 0 24px 4px rgba(255,77,216,.6)}}
@keyframes whiteFlash{0%{opacity:0; background:#fff}20%{opacity:.95; background:#fff}100%{opacity:0}}
@keyframes quake{0%,100%{transform:translate(0)}20%{transform:translate(-6px,4px)}40%{transform:translate(6px,-4px)}60%{transform:translate(-4px,-3px)}80%{transform:translate(4px,3px)}}
@keyframes partFly{0%{opacity:1; transform:translate(0,0)}100%{opacity:0; transform:translate(var(--dx),var(--dy)) rotate(300deg)}}

@media (prefers-reduced-motion: reduce){
  *{animation-duration:.001s !important; animation-iteration-count:1 !important; transition:none !important;}
}
@media (max-width:380px){ body{font-size:10px;} .logo{font-size:20px;} }

</style>
</head>
<body>
<div id="app">

  <!-- ============ TELA: TÍTULO ============ -->
  <div class="screen on" id="scr-title">
    <div class="logo">ENG<em>QUEST</em></div>
    <div class="tagline">⚔️ Responda. Evolua. Sobreviva. 📦</div>
    <div class="tagline" style="color:var(--line2)">Roguelike + Gacha de Inglês</div>
    <button class="btn" id="btn-start" style="font-size:13px; padding:16px 26px;">▶ INICIAR RUN</button>
    <div class="title-stats pxbox" id="meta-stats"></div>
  </div>

  <!-- ============ TELA: JOGO ============ -->
  <div class="screen" id="scr-game">
    <div id="hud">
      <div class="chip floor" id="chip-floor"></div>
      <div class="chip gold" id="chip-gold"></div>
      <div class="chip xp" id="chip-xp"></div>
      <div class="chip combo" id="chip-combo"></div>
      <button class="btn ghost small" id="btn-inv">🎒</button>
    </div>

    <div id="arena">
      <div class="torch l"></div><div class="torch r"></div>
      <div class="boss-tag" id="boss-tag" style="display:none">☠ BOSS ☠</div>
      <div class="fighter hero">
        <div class="name" id="hero-name">Herói</div>
        <canvas id="hero-cv"></canvas>
        <div class="hpbar"><i id="hero-hp-i"></i><span id="hero-hp-t"></span></div>
      </div>
      <div class="fighter enemy">
        <div class="name" id="enemy-name"></div>
        <canvas id="enemy-cv"></canvas>
        <div class="hpbar"><i id="enemy-hp-i"></i><span id="enemy-hp-t"></span></div>
      </div>
    </div>

    <div id="panel">
      <div id="qarea"></div>
      <div id="shop">
        <button class="btn ghost small" id="shop-heal">❤️ Curar 50%<br>40🪙</button>
        <button class="btn ghost small" id="shop-pack">📦 Pacote extra<br>55🪙</button>
        <button class="btn ghost small" id="shop-crit">💥 +10% Crítico<br>60🪙</button>
      </div>
    </div>
  </div>

  <!-- ============ TELA: RESUMO ============ -->
  <div class="screen" id="scr-summary">
    <div style="flex:1; overflow-y:auto; padding:20px; text-align:center;" id="sum-content"></div>
    <div style="display:flex; gap:10px; padding:14px; justify-content:center;">
      <button class="btn" id="btn-again">🔄 NOVA RUN</button>
      <button class="btn ghost" id="btn-title">🏠 MENU</button>
    </div>
  </div>

  <!-- overlay genérico (pacotes, itens, inventário, reviver) -->
  <div class="overlay" id="ovl"><div class="modal pxbox" id="modal"></div></div>
  <div id="toast"></div>
  <div class="flash" id="flash"></div>
</div>

<script>
/* ============================================================
   ENGQUEST — DATA LAYER
   Tudo que é conteúdo/balanceamento vive aqui.
   Para escalar o jogo: adicione entradas nestas tabelas,
   nenhuma mudança de lógica é necessária.
   ============================================================ */
"use strict";

/* ---------------- CONFIG DE BALANCEAMENTO ---------------- */
const CFG = {
  player:{ baseHp:60, baseDmg:6, healOnCorrect:0.08, reviveHp:0.30 },
  level:{ xpPerLevel:50, hpPerLevel:6, dmgPerLevel:1 },
  enemy:{ hp:(f)=>18+f*8, dmg:(f)=>3+Math.floor(f*1.4), bossMult:2.0, bossEvery:5 },
  reward:{ xp:(t)=>t*10, gold:(t)=>6+t*7, partialMult:0.5 },
  score:{ full:0.95, partial:0.40 },
  shop:{ heal:{cost:40,label:"Curar 50%"}, pack:{cost:55,label:"Pacote extra"},
         crit:{cost:60,label:"+10% Crítico"}, reroll:{cost:30,label:"Rerrolar"} },
  combo:[ {at:5, rareBonus:10, txt:"+10% chance rara"},
          {at:10, rareBonus:20, txt:"+20% chance rara"},
          {at:20, minPack:1, txt:"Pacote Raro garantido"},
          {at:30, minPack:2, txt:"Pacote Épico garantido"} ],
  srs:{ gaps:[3,5,8] },       // repetição espaçada: volta após N perguntas
  learnedAfter:2,             // acertos p/ marcar palavra como aprendida
};

/* ---------------- RARIDADES E PACOTES ---------------- */
const RARITIES = [
  { key:"comum",    name:"COMUM",    mult:1.0, sell:8  },
  { key:"raro",     name:"RARO",     mult:1.8, sell:18 },
  { key:"epico",    name:"ÉPICO",    mult:3.0, sell:40 },
  { key:"lendario", name:"LENDÁRIO", mult:5.0, sell:90 },
  { key:"mistico",  name:"MÍSTICO",  mult:8.5, sell:220 },
];
const PACKS = [
  { key:"comum",    name:"Pacote Comum",    col:"#8a90a0", odds:[70,25,4,1,0] },
  { key:"raro",     name:"Pacote Raro",     col:"#4da6ff", odds:[0,50,35,14,1] },
  { key:"epico",    name:"Pacote Épico",    col:"#b478ff", odds:[0,0,60,35,5] },
  { key:"lendario", name:"Pacote Lendário", col:"#ffc93c", odds:[0,0,30,60,10] },
];
// tier da pergunta -> índice do pacote
const PACK_BY_TIER = [0,0,0,1,1,2,2,2,3,3]; // idx 1..9

/* ---------------- EQUIPAMENTOS ---------------- */
// slot: arma | capacete | armadura | luvas | botas | escudo | anel | amuleto
const ITEM_TYPES = [
  { key:"espada",   nome:"Espada",   slot:"arma",     hp:0, dmg:4, sprite:"sword"  },
  { key:"machado",  nome:"Machado",  slot:"arma",     hp:0, dmg:5, sprite:"axe"    },
  { key:"arco",     nome:"Arco",     slot:"arma",     hp:0, dmg:4, sprite:"bow"    },
  { key:"cajado",   nome:"Cajado",   slot:"arma",     hp:2, dmg:3, sprite:"staff"  },
  { key:"adaga",    nome:"Adaga",    slot:"arma",     hp:0, dmg:3, sprite:"dagger" },
  { key:"martelo",  nome:"Martelo",  slot:"arma",     hp:2, dmg:5, sprite:"hammer" },
  { key:"capacete", nome:"Capacete", slot:"capacete", hp:5, dmg:0, sprite:"helm"   },
  { key:"armadura", nome:"Armadura", slot:"armadura", hp:9, dmg:0, sprite:"armor"  },
  { key:"luvas",    nome:"Luvas",    slot:"luvas",    hp:2, dmg:1, sprite:"gloves" },
