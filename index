      <div class="row"><span>Runs jogadas</span><b>${Meta.d.runs}</b></div>`;
  },
  startRun(){
    Run.reset(); Meta.d.runs++; Meta.save();
    UI.closeModal(); UI.show("scr-game");
    this.startFloor();
  },
  startFloor(){
    Run.enemy=Combat.enemyFor(Run.floor);
    UI.renderArena(); UI.refreshHud();
    if(Run.enemy.boss){ UI.toast("⚠️ BOSS! Sua build vai aguentar?",2200); Sfx.bad(); }
    this.askQuestion();
  },
  askQuestion(){
    const tier=Quiz.tierForFloor(Run.floor);
    const {q,review}=Quiz.pick(tier);
    Run.currentQ=q; Run.isReview=review;
    let ptext=q.p, dialog="";
    if(q.p.includes("|||")){ const parts=q.p.split("|||"); dialog=`<span class="dialog">💬 ${parts[0]}</span>`; ptext=parts[1]; }
    $("qarea").innerHTML=`
      <div class="qcard pxbox">
        <div class="qtier"><span>TIER ${q.tier} · ${TIER_NAMES[q.tier].toUpperCase()}</span>
          ${review?`<span class="rev">🔁 REVISÃO</span>`:""}</div>
        <div class="qtext">${dialog}${ptext}</div>
        <input id="answer" type="text" autocomplete="off" autocapitalize="off" placeholder="Digite em inglês...">
        <div class="qactions"><button class="btn" id="btn-send">RESPONDER ⚡</button></div>
      </div>`;
    $("shop").style.display="flex";
    Run.answering=true;
    $("btn-send").onclick=()=>this.submit();
    $("answer").addEventListener("keydown",e=>{ if(e.key==="Enter") this.submit(); });
    UI.refreshHud();
  },
  submit(){
    if(!Run.answering) return;              // trava re-submissão (Enter repetido / double-tap)
    const given=$("answer").value;
    if(!given.trim()){ UI.toast("Digite uma resposta!"); return; }
    Run.answering=false;
    const sendBtn=$("btn-send"); if(sendBtn) sendBtn.style.pointerEvents="none";
    const q=Run.currentQ;
    const r=Scorer.evaluate(given,q);
    const full=r.score>=CFG.score.full, partial=!full&&r.score>=CFG.score.partial;
    const tier=q.tier;
    Quiz.registerResult(q,full,partial);

    let xp=0,gold=0;
    if(full){
      Run.combo++; Run.maxCombo=Math.max(Run.maxCombo,Run.combo);
      const m=CFG.combo.find(c=>c.at===Run.combo);
      if(m) UI.toast(`🔥 COMBO x${Run.combo}! ${m.txt}`,2200);
      xp=CFG.reward.xp(tier); gold=CFG.reward.gold(tier);
      Run.hp=Math.min(Run.maxHp(),Run.hp+Math.round(Run.maxHp()*CFG.player.healOnCorrect));
      Run.pendingPack=Gacha.packIdxForTier(tier,false);
      Sfx.ok(); Sfx.coin();
    } else if(partial){
      xp=Math.round(CFG.reward.xp(tier)*CFG.reward.partialMult);
      gold=Math.round(CFG.reward.gold(tier)*CFG.reward.partialMult);
      Run.pendingPack=Gacha.packIdxForTier(tier,true);
      Sfx.partial();
    } else {
      Run.combo=0; Run.pendingPack=null; Sfx.bad();
    }
    Run.addXp(xp); Run.addGold(gold);
    if(Run.isReview&&full) UI.toast("🧠 Palavra revisada com sucesso!");
    UI.refreshHud(); UI.refreshBars();
    this.showFeedback(r,full,partial,xp,gold,q);
  },
  showFeedback(r,full,partial,xp,gold,q){
    const pct=Math.round(r.score*100);
    const cls=full?"ok":partial?"partial":"bad";
    const head=full?"✅ PERFEITO!":partial?"⚠️ QUASE LÁ!":"❌ ERROU!";
    const wordDiff=r.missing.length?
      `<div class="line">❌ Faltou/errou: ${r.missing.map(w=>`<span class="wordmiss">${w}</span>`).join(" · ")}</div>`:"";
    const extras=r.extra.length?
      `<div class="line">✂️ Sobrou: ${r.extra.map(w=>`<span class="wordbad">${w}</span>`).join(" · ")}</div>`:"";
    const okWords=partial&&r.matched.length?
      `<div class="line">👍 Você acertou: ${r.matched.map(w=>`<span class="wordok">${w}</span>`).join(" · ")}</div>`:"";
    const rew=(full||partial)?
      `<div class="rewards"><span>⭐ +${xp} XP</span><span>🪙 +${gold}</span><span>📦 ${PACKS[Run.pendingPack].name}${partial?" (inferior)":""}</span></div>`:
      `<div class="rewards"><span style="color:var(--bad)">Sem pacote desta vez... 📦❌</span></div>`;
    $("qarea").innerHTML=`
      <div class="fb pxbox ${cls}">
        <div class="head">${head}</div>
        <div class="pct" style="color:var(--${cls==="ok"?"ok":cls==="partial"?"warn":"bad"})">${pct}%</div>
        <div class="line">✅ Resposta correta: <b>${r.ans}</b></div>
        ${okWords}${wordDiff}${extras}
        <div class="line">📖 ${q.note}</div>
        <div class="line">💡 ${q.tr}</div>
        <div class="line">🔁 ${q.ex}</div>
        ${rew}
        <div class="qactions"><button class="btn blue" id="btn-cont">CONTINUAR ▶</button></div>
      </div>`;
    $("shop").style.display="none";
    UI.once($("btn-cont"),()=>{
      if(Run.pendingPack!=null){ const p=Run.pendingPack; Run.pendingPack=null; this.openPack(p,()=>Combat.start()); }
      else Combat.start();
    });
  },
  /* ---------- GACHA / PACOTES ---------- */
  openPack(packIdx,onDone){
    const P=PACKS[packIdx];
    Sfx.pack();
    UI.modal(`
      <div class="packwrap">
        <div class="packname" style="color:${P.col}">${P.name.toUpperCase()}</div>
        <div class="pack" id="packbtn" style="--pc:${P.col};--pcl:${P.col}cc;--pcd:#0a0816"><span>❓</span></div>
